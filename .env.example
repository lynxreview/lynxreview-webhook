# ============================================
# LynxReview Backend - Environment Variables
# ============================================

# Server
NODE_ENV=production
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/lynxreview?retryWrites=true&w=majority

# JWT Secret (generate a random string of 64+ chars)
JWT_SECRET=your-jwt-secret-here-change-this-to-a-random-string

# Encryption Key for Google tokens (MUST be exactly 32 characters)
ENCRYPTION_KEY=12345678901234567890123456789012

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://lynxreview-webhook.onrender.com/api/auth/google/callback

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Admin Credentials (created on first run)
ADMIN_EMAIL=admin@lynxreview.com
ADMIN_PASSWORD=change-this-password-in-production
